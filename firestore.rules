rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Stats collection
    match /stats/{statsId} {
      allow read: if true; // Publicly readable for the counter
      allow create: if isValidId(statsId) 
                   && incoming().visitCount is number
                   && incoming().keys().size() == 1;
      allow update: if isValidId(statsId)
                   && incoming().visitCount is number
                   && incoming().visitCount == existing().visitCount + 1
                   && incoming().keys().size() == 1;
    }
  }
}
