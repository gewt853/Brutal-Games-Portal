rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Stats collection
    match /stats/{statsId} {
      allow read: if true;
      allow create, update: if true; // Simple visit counter for this demo
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow read: if true; // Admin needs to see sessions
      allow write: if isValidId(sessionId); // Users can create/update their session
    }

    // Bans collection
    match /bans/{banId} {
      allow read: if true; // App needs to check if current user is banned
      allow write: if true; // In this setup we don't have true auth-based admin check in rules yet without Firebase Auth
    }
  }
}
